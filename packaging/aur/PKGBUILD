# Maintainer: Pranav Kannepalli <pranav.kannepalli@gmail.com>
pkgname=linux-archductor
pkgver=0.1.0
pkgrel=1
pkgdesc="Linux-native parallel coding-agent workflow tool built around Git worktrees"
arch=('x86_64')
url="https://github.com/pranavkannepalli/conductor-arch"
license=('MIT')
depends=('git' 'github-cli' 'sqlite' 'openssh' 'gtk4' 'libadwaita')
makedepends=('rust' 'cargo' 'pkgconf')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "conductor-arch-$pkgver"
    cargo build --release --locked --workspace
}

package() {
    cd "conductor-arch-$pkgver"
    install -Dm755 target/release/linux-archductor "$pkgdir/usr/bin/linux-archductor"
    install -Dm755 target/release/linux-archductor-gtk "$pkgdir/usr/bin/linux-archductor-gtk"
    install -Dm644 packaging/linux-archductor-gtk.desktop \
        "$pkgdir/usr/share/applications/linux-archductor-gtk.desktop"
    install -Dm644 packaging/linux-archductor.svg \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/linux-archductor.svg"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
